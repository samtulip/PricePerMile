{
  "name": "pricepermile-monorepo",
  "version": "0.1.0",
  "description": "PricePerMile monorepo - fuel price comparison and related services",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/frontend",
    "build": "npm run build --workspace=packages/frontend",
    "start": "npm run start --workspace=packages/frontend",
    "lint": "npm run lint --workspace=packages/frontend",
    "export": "npm run export --workspace=packages/frontend",
    "convert:stations": "npm run convert:stations --workspace=packages/frontend"
  }
}
